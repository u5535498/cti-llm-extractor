{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/cti-extraction-schema-v0.2.json",
  "title": "CTI Extraction Schema v0.2",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "report_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "report_title": { "type": "string", "minLength": 1 },
        "report_type": {
          "type": "string",
          "enum": ["incident", "campaign", "strategic"]
        }
      },
      "required": ["report_type"]
    },

    "threat_actor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      },
      "required": ["name", "aliases", "confidence"]
    },

    "campaign_name": { "type": "string" },

    "target_sectors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },

    "indicators_of_compromise": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ip_addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "evidence_snippet": { "type": "string", "minLength": 1 },
              "source_context": {
                "type": "string",
                "enum": ["observed", "detection_rule_only", "uncertain", "historical"]
              }
            },
            "required": ["value", "evidence_snippet"]
          },
          "default": []
        },

        "domains": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "evidence_snippet": { "type": "string", "minLength": 1 },
              "source_context": {
                "type": "string",
                "enum": ["observed", "detection_rule_only", "uncertain", "historical"],
                "default": "observed"
              },
              "masked": { "type": "boolean", "default": false },
              "phishing_template": { "type": "boolean", "default": false }
            },
            "required": ["value", "evidence_snippet"]
          },
          "default": []
        },

        "file_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "hash_type": {
                "type": "string",
                "enum": ["MD5", "SHA1", "SHA256", "SHA512", "SSDEEP"]
              },
              "evidence_snippet": { "type": "string", "minLength": 1 },
              "source_context": {
                "type": "string",
                "enum": ["observed", "detection_rule_only", "uncertain", "historical"]
              }
            },
            "required": ["value", "hash_type", "evidence_snippet"]
          },
          "default": []
        },

        "urls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "evidence_snippet": { "type": "string", "minLength": 1 },
              "source_context": {
                "type": "string",
                "enum": ["observed", "detection_rule_only", "uncertain", "historical"]
              }
            },
            "required": ["value", "evidence_snippet"]
          },
          "default": []
        },

        "http_paths": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "evidence_snippet": { "type": "string", "minLength": 1 },
              "source_context": {
                "type": "string",
                "enum": ["observed", "detection_rule_only", "uncertain", "historical"]
              }
            },
            "required": ["value", "evidence_snippet"]
          },
          "default": []
        },

        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "evidence_snippet": { "type": "string", "minLength": 1 }
            },
            "required": ["name", "evidence_snippet"]
          },
          "default": []
        },

        "cves": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "evidence_snippet": { "type": "string", "minLength": 1 }
            },
            "required": ["value", "evidence_snippet"]
          },
          "default": []
        },

        "detection_signatures": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "yara_rules": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "evidence_snippet": { "type": "string", "minLength": 1 }
                },
                "required": ["name", "evidence_snippet"]
              },
              "default": []
            },
            "sigma_rules": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "evidence_snippet": { "type": "string", "minLength": 1 }
                },
                "required": ["name", "evidence_snippet"]
              },
              "default": []
            }
          },
          "default": {}
        }
      },
      "required": ["ip_addresses", "domains", "file_hashes", "urls", "http_paths", "tools", "cves", "detection_signatures"]
    },

    "ttps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mitre_id": {
            "type": "string",
            "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$"
          },
          "tactic": { "type": "string", "minLength": 1 },
          "technique": { "type": "string", "minLength": 1 },
          "evidence_snippet": { "type": "string", "minLength": 1 },
          "mapping_type": {
            "type": "string",
            "enum": ["explicit", "inferred"],
            "default": "explicit"
          },
          "mitre_confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "evidence_location": { "type": "string" }
        },
        "required": ["tactic", "technique", "evidence_snippet"]
      },
      "default": []
    },

    "summary": {
      "type": "string",
      "maxLength": 1500
    },

    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "date_precision": {
            "type": "string",
            "enum": ["day", "month", "quarter", "year", "approximate"],
            "default": "day"
          },
          "event": { "type": "string", "minLength": 1 },
          "evidence_snippet": { "type": "string", "minLength": 1 }
        },
        "required": ["date", "event", "evidence_snippet"]
      },
      "default": []
    }
  },

  "required": [
    "report_metadata",
    "indicators_of_compromise",
    "ttps",
    "summary",
    "timeline"
  ]
}
